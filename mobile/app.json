{
  "expo": {
    "name": "NutriPulse",
    "slug": "nutripulse",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "nutripulse",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#030510"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.nutripulse.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#030510"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.nutripulse.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow NutriPulse to access your camera for food photo analysis."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow NutriPulse to access your photos for food analysis."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
